{
  "expo": {
    "name": "Contpose",
    "slug": "contpose",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "myapp",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSCameraUsageDescription": "Permite usar la cámara para análisis postural en vivo.",
        "NSMicrophoneUsageDescription": "Permite usar el micrófono si se solicita audio en futuras funciones.",
        "ITSAppUsesNonExemptEncryption": false
      },
      "bundleIdentifier": "y"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.CAMERA"
      ],
      "package": "com.ericalaya0sorganization.contpose"
    },
    "web": {
      "bundler": "metro",
      "output": "single",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-image-picker",
        {
          "photosPermission": "Permite seleccionar una foto para tu perfil.",
          "cameraPermission": "Permite usar la camara para tomar tu foto de perfil."
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "Permite usar la camara para analisis postural en vivo."
        }
      ],
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#ffffff"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "397d9a5e-36b7-42c9-b30d-c75be9f0a09b"
      }
    },
    "owner": "ericalaya0s-organization"
  }
}
